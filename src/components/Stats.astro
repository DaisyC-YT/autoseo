---
const stats = [
  { value: '500+', label: 'Companies Using Auto SEO', sub: 'From startups to enterprise' },
  { value: '218%', label: 'Avg. Traffic Growth', sub: 'Within the first 90 days' },
  { value: '12M+', label: 'Keywords Tracked Daily', sub: 'Across all customer sites' },
  { value: '< 5 min', label: 'Time to First Insight', sub: 'From sign-up to live dashboard' },
];
---

<section id="stats" class="py-20 bg-white border-y border-gray-100">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-4">
      {stats.map((s, i) => (
        <div class={`text-center ${i < stats.length - 1 ? 'lg:border-r lg:border-gray-100' : ''}`}>
          <p class="text-4xl sm:text-5xl font-black text-gray-900 tracking-tight mb-1">
            {s.value}
          </p>
          <p class="text-sm font-semibold text-gray-700 mb-1">{s.label}</p>
          <p class="text-xs text-gray-400">{s.sub}</p>
        </div>
      ))}
    </div>
  </div>
</section>
