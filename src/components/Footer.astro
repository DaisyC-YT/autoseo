---
const links = {
  'Services': ['Auto SEO Crawl', 'Keyword Research', 'Data Analytics', 'Rank Tracking', 'Site Audit'],
  'Company': ['About Us', 'Case Studies', 'Partners', 'Careers'],
  'Resources': ['SEO Blog', 'Help Center', 'API Docs', 'Privacy Policy'],
};

const year = new Date().getFullYear();
---

<footer class="bg-gray-900 text-gray-400">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-10 mb-12">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center gap-2.5 mb-4">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-blue-500 to-violet-600 flex items-center justify-center">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <span class="font-bold text-white text-lg">Auto SEO</span>
        </a>
        <p class="text-sm leading-relaxed mb-6 max-w-xs">
          Your AI-powered SEO platform — automate crawling, keyword research, and data analytics to rank faster with less effort.
        </p>

        <!-- Social links -->
        <div class="flex gap-3">
          {[
            { label: 'LinkedIn', href: '#', icon: `<svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>` },
            { label: 'Facebook', href: '#', icon: `<svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>` },
            { label: 'LINE', href: '#', icon: `<svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M21.7 10.3C21.7 5.8 17.3 2 12 2S2.3 5.8 2.3 10.3c0 4.1 3.6 7.5 8.5 8.1.3.1.8.3.9.6.1.3.1.7 0 1l-.1.8c0 .3-.2.9.8.5 1-.4 5.3-3.1 7.2-5.3 1.3-1.5 2.1-3.1 2.1-4.7z"/></svg>` },
          ].map((s) => (
            <a
              href={s.href}
              aria-label={s.label}
              class="w-8 h-8 rounded-lg bg-gray-800 hover:bg-gray-700 flex items-center justify-center text-gray-400 hover:text-white transition"
              set:html={s.icon}
            />
          ))}
        </div>
      </div>

      <!-- Nav links -->
      {Object.entries(links).map(([category, items]) => (
        <div>
          <h4 class="text-white font-semibold text-sm mb-4">{category}</h4>
          <ul class="space-y-2.5">
            {items.map((item) => (
              <li>
                <a href="#" class="text-sm hover:text-white transition-colors">{item}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-gray-800 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs">© {year} Auto SEO. All rights reserved.</p>
      <div class="flex items-center gap-4 text-xs">
        <a href="#" class="hover:text-white transition-colors">隱私權政策</a>
        <a href="#" class="hover:text-white transition-colors">服務條款</a>
        <a href="#" class="hover:text-white transition-colors">Cookie 設定</a>
      </div>
    </div>
  </div>
</footer>
