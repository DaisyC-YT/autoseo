---
const testimonials = [
  {
    quote: 'Auto SEO\'s crawler found 240 technical issues we didn\'t know existed. After fixing them, our organic traffic jumped 40% in 6 weeks. The keyword clustering alone saved my team 10 hours a week.',
    name: 'Sarah Chen',
    role: 'Head of SEO · E-commerce Brand',
    avatar: 'S',
    color: 'blue',
  },
  {
    quote: 'The AI-generated weekly reports are incredible. I share them directly with clients — they look professional and actually explain why rankings moved. Our agency retained 3 clients specifically because of this feature.',
    name: 'Marcus Webb',
    role: 'Founder · Digital Marketing Agency',
    avatar: 'M',
    color: 'violet',
  },
  {
    quote: 'We used to spend two days a month doing keyword research manually. Auto SEO does it in minutes and finds opportunities we would have missed. Our blog traffic grew 218% in 90 days.',
    name: 'Priya Nair',
    role: 'Content Strategist · SaaS Company',
    avatar: 'P',
    color: 'green',
  },
];

const avatarColor: Record<string, string> = {
  blue:   'bg-blue-100 text-blue-600',
  violet: 'bg-violet-100 text-violet-600',
  green:  'bg-green-100 text-green-600',
};
---

<section id="testimonials" class="py-24 bg-gray-50">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <span class="text-sm font-semibold text-blue-600 tracking-widest uppercase mb-3 block">Testimonials</span>
      <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">What our customers say</h2>
      <p class="text-gray-500 max-w-xl mx-auto">
        Real results from real teams who automated their SEO with Auto SEO.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {testimonials.map((t) => (
        <div class="bg-white border border-gray-100 rounded-2xl p-6 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-200">
          <div class="flex gap-0.5 mb-4">
            {Array(5).fill(0).map(() => (
              <svg width="14" height="14" viewBox="0 0 24 24" fill="#f59e0b" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            ))}
          </div>
          <p class="text-sm text-gray-600 leading-relaxed mb-6">"{t.quote}"</p>
          <div class="flex items-center gap-3">
            <div class={`w-10 h-10 rounded-full flex items-center justify-center font-bold text-sm ${avatarColor[t.color]}`}>
              {t.avatar}
            </div>
            <div>
              <p class="text-sm font-semibold text-gray-900">{t.name}</p>
              <p class="text-xs text-gray-400">{t.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
