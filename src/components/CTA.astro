---
---

<section id="contact" class="py-24 bg-white">
  <div class="max-w-4xl mx-auto px-6">
    <div class="relative bg-gradient-to-br from-blue-600 to-violet-700 rounded-3xl p-10 sm:p-14 text-center overflow-hidden shadow-xl shadow-blue-200">
      <!-- Background decoration -->
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute -top-10 -right-10 w-60 h-60 bg-white/5 rounded-full"></div>
        <div class="absolute -bottom-10 -left-10 w-72 h-72 bg-white/5 rounded-full"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-white/5 rounded-full blur-3xl"></div>
      </div>

      <div class="relative z-10">
        <div class="inline-flex items-center gap-2 bg-white/10 text-white text-xs font-semibold px-3 py-1.5 rounded-full mb-6 border border-white/20">
          <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse"></span>
          Free 14-day trial · No credit card required
        </div>

        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4 leading-tight">
          Ready to automate<br />your SEO?
        </h2>
        <p class="text-blue-100 text-base max-w-xl mx-auto mb-10">
          Join 500+ companies using Auto SEO to crawl smarter, find better keywords,
          and turn data into rankings. Set up in under 5 minutes.
        </p>

        <!-- Form -->
        <form class="flex flex-col sm:flex-row gap-3 max-w-lg mx-auto mb-6">
          <input
            type="email"
            placeholder="Enter your work email..."
            class="flex-1 px-4 py-3.5 rounded-xl bg-white/10 border border-white/20 text-white placeholder-blue-200 focus:outline-none focus:border-white/50 focus:bg-white/20 transition text-sm"
            required
          />
          <button
            type="submit"
            class="bg-white text-blue-700 font-bold px-6 py-3.5 rounded-xl hover:bg-blue-50 transition-colors whitespace-nowrap text-sm shadow-sm"
          >
            Start Free Trial
          </button>
        </form>

        <p class="text-blue-200 text-xs">
          Free for 14 days &bull; No setup fees &bull; Cancel anytime
        </p>
      </div>
    </div>
  </div>
</section>
